# LLM API Key (required)
ANTHROPIC_API_KEY=your-api-key-here

# Database (required for Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coding_agent

# Agent connects to server (required when server port differs from 3000)
AGENT_SERVER_URL=http://localhost:3000

# Local agent file sandbox (gitignored). The agent package `npm run dev` uses ../../.agent-workspace
# from packages/agent. Override when invoking the CLI manually: --working-dir /path/to/sandbox

# Shared workspace directory for session file downloads
# In Docker, both server and agent mount this volume. Falls back to agent's registered workingDir.
# WORKSPACE_DIR=/workspace

# Host port mappings (change if defaults conflict)
DB_PORT=5432
SERVER_PORT=3000
WEB_PORT=5173
